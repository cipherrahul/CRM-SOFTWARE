{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identity/{**catch-all}" }
      },
      "crm-route": {
        "ClusterId": "crm-cluster",
        "Match": { "Path": "/api/crm/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/ai/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/analytics/{**catch-all}" }
      },
      "file-route": {
        "ClusterId": "file-cluster",
        "Match": { "Path": "/api/files/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5001" } }
      },
      "crm-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5002" } }
      },
      "ai-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5003" } }
      },
      "notification-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5004" } }
      },
      "analytics-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5005" } }
      },
      "file-cluster": {
        "Destinations": { "dest1": { "Address": "http://localhost:5006" } }
      }
    }
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_256_BIT_SECRET_KEY_IN_PRODUCTION",
    "Issuer": "CRM.IdentityService",
    "Audience": "CRM.Client"
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } }
  },
  "AllowedHosts": "*"
}
